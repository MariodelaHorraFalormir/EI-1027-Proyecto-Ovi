+package es.uji.ei1027.ovi.controller;
+
+import es.uji.ei1027.ovi.dao.OviUserDao;
+import es.uji.ei1027.ovi.dao.PersonaDao;
+import es.uji.ei1027.ovi.modelo.Persona.Roles.OviUser;
+import es.uji.ei1027.ovi.validator.OviUserValidator;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.stereotype.Controller;
+import org.springframework.ui.Model;
+import org.springframework.validation.BindingResult;
+import org.springframework.web.bind.annotation.*;
+
+@Controller
+@RequestMapping("/OviUser")
+public class OviUserController {
+
+    private OviUserDao oviUserDao;
+    private PersonaDao personaDao;
+    private OviUserValidator oviUserValidator;
+
+    @Autowired
+    public void setOviUserDao(OviUserDao oviUserDao) {
+        this.oviUserDao = oviUserDao;
+    }
+
+    @Autowired
+    public void setPersonaDao(PersonaDao personaDao) {
+        this.personaDao = personaDao;
+    }
+
+    @Autowired
+    public void setOviUserValidator(OviUserValidator oviUserValidator) {
+        this.oviUserValidator = oviUserValidator;
+    }
+
+    @GetMapping("/list")
+    public String listOviUsers(Model model) {
+        // Asumiendo que añades un método getOviUsers() en tu DAO que devuelva List<OviUser>
+        // Si no, puedes usar personaDao.getPersonasOrderId() temporalmente
+        model.addAttribute("oviUsers", personaDao.getPersonasOrderId());
+        return "OviUser/list";
+    }
+
+    @GetMapping("/add")
+    public String addOviUser(Model model) {
+        model.addAttribute("oviUser", new OviUser());
+        return "OviUser/add";
+    }
+
+    @PostMapping("/add")
+    public String processAddSubmit(@ModelAttribute("oviUser") OviUser oviUser,
+                                   BindingResult bindingResult) {
+        oviUserValidator.validate(oviUser, bindingResult);
+        if (bindingResult.hasErrors())
+            return "OviUser/add";
+
+        int idPersona = personaDao.addPersonaYDevolverId(oviUser);
+        oviUserDao.addOviUser(idPersona);
+
+        return "redirect:/OviUser/list";
+    }
+
+    @GetMapping("/update/{id}")
+    public String editOviUser(Model model, @PathVariable int id) {
+        model.addAttribute("oviUser", personaDao.getPersona(id));
+        return "OviUser/update";
+    }
+
+    @PostMapping("/update")
+    public String processUpdateSubmit(@ModelAttribute("oviUser") OviUser oviUser,
+                                      BindingResult bindingResult) {
+        oviUserValidator.validate(oviUser, bindingResult);
+        if (bindingResult.hasErrors())
+            return "OviUser/update";
+
+        personaDao.updatePersona(oviUser);
+        return "redirect:/OviUser/list";
+    }
+}
